# ============================================================
# LLM API Pricing Updater — 환경변수 설정
# ============================================================
# 이 파일을 .env로 복사한 뒤 실제 값으로 교체하세요:
#   cp .env.example .env
#
# .env는 .gitignore에 포함되어 있어 커밋되지 않습니다.
# ============================================================

# ------------------------------------------------------------
# [선택] LLM Proxy Server URL
# ------------------------------------------------------------
# 가격 페이지 텍스트를 LLM으로 파싱할 때 프록시 서버를 경유합니다.
# API key는 프록시가 관리하므로 별도 설정 불필요.
# 기본값: http://192.168.0.2:8081
#
# LLM_PROXY_URL=http://192.168.0.2:8081

# ------------------------------------------------------------
# [필수] Telegram Bot Token
# ------------------------------------------------------------
# 가격 변동 알림을 보낼 Telegram 봇의 토큰입니다.
#
# 봇 생성 방법:
#   1. Telegram에서 @BotFather 검색
#   2. /newbot 명령어로 봇 생성
#   3. 발급된 토큰을 여기에 입력
#
# 예시:
#   TELEGRAM_BOT_TOKEN=7123456789:AAF1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=

# ------------------------------------------------------------
# [필수] Telegram Chat ID
# ------------------------------------------------------------
# 알림을 받을 채팅방의 ID입니다.
#
# Chat ID 확인 방법:
#   1. 봇에게 아무 메시지를 보낸 뒤
#   2. 브라우저에서 열기: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#   3. 응답 JSON에서 "chat":{"id": 숫자} 부분이 Chat ID
#
# 개인 채팅: 양수 (예: 123456789)
# 그룹 채팅: 음수 (예: -100123456789)
# 채널:      음수 (예: -100987654321)
#
# 예시:
#   TELEGRAM_CHAT_ID=123456789
#   TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# [선택] LLM 파싱에 사용할 모델
# ------------------------------------------------------------
# 기본값: claude-haiku-4-5 (가장 저렴, 하루 ~$0.001 미만)
#
# 사용 가능한 모델 예시:
#   LLM_MODEL=claude-haiku-4-5      # Anthropic — $1.00/$5.00 per 1M tokens (기본값)
#   LLM_MODEL=claude-sonnet-4-6     # Anthropic — $3.00/$15.00 (더 정확하지만 비쌈)
#   LLM_MODEL=claude-haiku-3-5      # Anthropic — $0.80/$4.00 (구버전, 약간 저렴)
#
# LLM_MODEL=claude-haiku-4-5
